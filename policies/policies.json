{
  "version": "0.1.0",
  "policies": [
    {
      "id": "CYBER-ID-001",
      "name": "Rapid account takeover sequence",
      "match": {
        "threat": "stolen_admin_session",
        "min_confidence": 0.85,
        "required_signals": ["new_device", "mfa_disabled", "recovery_changed"]
      },
      "decision": "approve",
      "allowed_action": "revoke_sessions",
      "max_scope": "single_identity",
      "reversible": true,
      "human_approval_required": false
    },
    {
      "id": "CYBER-RW-001",
      "name": "Ransomware containment",
      "match": {
        "threat": "ransomware",
        "min_confidence": 0.9,
        "required_signals": ["rapid_file_rewrite", "recovery_deletion_attempt"]
      },
      "decision": "approve",
      "allowed_action": "isolate_endpoint",
      "max_scope": "single_endpoint",
      "reversible": true,
      "human_approval_required": false
    },
    {
      "id": "CYBER-AI-001",
      "name": "Prompt-injection tool abuse",
      "match": {
        "threat": "prompt_injection",
        "min_confidence": 0.8,
        "required_signals": ["untrusted_instruction", "secret_access_request"]
      },
      "decision": "deny",
      "allowed_action": "none",
      "max_scope": "single_agent",
      "reversible": true,
      "human_approval_required": false
    },
    {
      "id": "CYBER-EX-001",
