{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/emilyecht/cerberuscyber/schemas/policy-bundle.schema.json",
  "title": "CERBERUS Guardian Policy Bundle v1.0.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "version",
    "decision_ttl_seconds",
    "min_independent_sources",
    "escalation_signals",
    "scope_order",
    "policies",
    "forbidden_actions"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "decision_ttl_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
    "min_independent_sources": {"type": "integer", "minimum": 1, "maximum": 64},
    "escalation_signals": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "scope_order": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "prefixItems": [{"const": "none"}],
      "items": {"type": "string", "minLength": 1}
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/policy"}
    },
    "forbidden_actions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "not": {"const": "none"}
      }
    }
  },
  "$defs": {
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "threat",
        "min_confidence",
        "required_signals",
        "min_independent_sources"
      ],
      "properties": {
        "threat": {"type": "string", "minLength": 1},
        "min_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "required_signals": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "min_independent_sources": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "match",
        "decision",
        "allowed_action",
        "max_scope",
        "reversible_required",
        "human_approval_required",
        "required_approval_count"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "match": {"$ref": "#/$defs/match"},
        "decision": {"enum": ["approve", "escalate", "deny"]},
        "decision_on_approval": {"enum": ["approve", "deny"]},
        "allowed_action": {"type": "string", "minLength": 1},
        "max_scope": {"type": "string", "minLength": 1},
        "reversible_required": {"type": "boolean"},
        "human_approval_required": {"type": "boolean"},
        "required_approval_count": {"type": "integer", "minimum": 0, "maximum": 8}
      },
      "allOf": [
        {
          "if": {"properties": {"decision": {"const": "deny"}}},
          "then": {
            "properties": {
              "allowed_action": {"const": "none"},
              "max_scope": {"const": "none"},
              "human_approval_required": {"const": false},
              "required_approval_count": {"const": 0}
            },
            "not": {"required": ["decision_on_approval"]}
          }
        },
        {
          "if": {"properties": {"decision": {"const": "approve"}}},
          "then": {
            "properties": {"allowed_action": {"not": {"const": "none"}}},
            "not": {"required": ["decision_on_approval"]}
          }
        },
        {
          "if": {
            "properties": {
              "decision": {"const": "escalate"},
              "human_approval_required": {"const": true}
            },
            "required": ["decision", "human_approval_required"]
          },
          "then": {"required": ["decision_on_approval"]}
        }
      ]
    }
  }
}
